generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  profile   Profile?
  createdAt DateTime @default(now())
}

model Profile {
  id         Int     @id @default(autoincrement())
  user       User    @relation(fields: [userId], references: [id])
  userId     Int     @unique
  memberName String?
  gender     String?
  age        Int?
  weight     Float?
  height     Float?
  activity   String?
  goal       String?
  result     Json?
}
